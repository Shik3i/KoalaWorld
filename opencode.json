{
  "$schema": "https://opencode.ai/config.json",

  "model": "koala-local/google/gemma-4-e4b",

  "enabled_providers": ["koala-local"],

  "provider": {
    "koala-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Koala Local LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "local",
        "timeout": 900000,
        "chunkTimeout": 120000
      },
      "models": {
        "google/gemma-4-e4b": {
          "name": "Google Gemma 4 E4B local",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b-uncensored-hauhaucs-aggressive": {
          "name": "Qwen 3.6 35B A3B Uncensored local",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "nvidia/nemotron-3-nano-4b": {
          "name": "NVIDIA Nemotron 3 Nano 4B local",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "qwen3.5-0.8b": {
          "name": "Qwen 3.5 0.8B tiny local",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },

  "permission": {
    "edit": "ask",
    "bash": "ask"
  },

  "share": "disabled",
  "autoupdate": false
}